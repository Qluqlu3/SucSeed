<div class="alert-box">
  <% flash.each do |key, value| %>
    <div class="alert alert-<%= key %>"><%= value %></div>
  <% end %>
</div>

<%= content_tag :div, '', data: { react_component: 'PasswordForgotPage', props: {}.to_json } %>

    <div class="alert alert-<%= key %>"><%= value %></div>
  <% end %>
</div>

<div>
  <%= form_for :user_email, url: "/user/password_forgot" do |f| %>
    <div class="input-group">
      <%= f.label "メールアドレス", class: "input-group-addon" %>
      <%= f.email_field :email, class: "form-control", placeholder: "メールアドレス" %>
    </div>

    <div class="right_side">
      <%= f.submit "変更", class: "btn btn-primary btn-lg" %>
    </div>
  <% end %>
</div>
