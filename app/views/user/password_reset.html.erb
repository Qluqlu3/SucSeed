<div class="alert-box">
  <% flash.each do |key, value| %>
    <div class="alert alert-<%= key %>"><%= value %></div>
  <% end %>
</div>

<% page_props = { errors: @user&.errors&.full_messages || [] } %>
<%= content_tag :div, '', data: { react_component: 'PasswordResetPage', props: page_props.to_json } %>

