<%= stylesheet_link_tag "index" %>

<%# フラッシュメッセージは Rails 側で処理（サーバーで消費されるため React に渡さない） %>
<div class="alert-box">
  <% flash.each do |key, value| %>
    <div class="alert alert-<%= key %>"><%= value %></div>
  <% end %>
</div>

<%
  page_props = {
    creators: @creator.map { |c|
      {
        userId:     c.user_id,
        name:       c.name,
        title:      c.title,
        avatarPath: c.avatar_path.to_s,
        createdAt:  c.created_at,
      }
    },
  }
%>
<%= content_tag :div, '', data: { react_component: 'SearchUserPage', props: page_props.to_json } %>
