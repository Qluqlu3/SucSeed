<%= stylesheet_link_tag "inquiry" %>

<%# フラッシュメッセージは Rails 側で処理（サーバーで消費されるため React に渡さない） %>
<div class="alert-box">
  <% flash.each do |key, value| %>
    <div class="alert alert-<%= key %>"><%= value %></div>
  <% end %>
</div>

<%
  page_props = {
    categories: @categories.map { |c| { id: c.id, name: c.name } },
    errors: @inquiry.errors.full_messages,
    prevValues: {
      inquiryCategoryId: @inquiry.inquiry_category_id || '',
      content:           @inquiry.content.to_s,
    },
  }
%>
<%= content_tag :div, '', data: { react_component: 'InquiryInputPage', props: page_props.to_json } %>