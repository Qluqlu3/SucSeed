<%= stylesheet_link_tag "gallery" %>

<div class="alert-box">
  <% flash.each do |key, value| %>
    <div class="alert alert-<%= key %>"><%= value %></div>
  <% end %>
</div>

<%
  page_props = {
    galleries: @favorite_gallery.map { |g|
      {
        id:        g.page_id,
        dataUrl:   g.data.to_s,
        tags:      g.tag_list.to_a,
        goodCount: 0,
        myGood:    false
      }
    }
  }
%>
<%= content_tag :div, '', data: { react_component: 'HeirFavoriteGalleryPage', props: page_props.to_json } %>
