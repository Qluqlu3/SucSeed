<%= stylesheet_link_tag "heir" %>

<%# フラッシュメッセージは Rails 側で処理 %>
<div class="alert-box">
  <% flash.each do |key, value| %>
    <div class="alert alert-<%= key %>"><%= value %></div>
  <% end %>
</div>

<%
  page_props = {
    heir: {
      artCategoryId: @heir.art_category_id,
      introduction:  @heir.introduction.to_s,
    },
    artCategories: @art_categories.map { |c| { id: c.id, name: c.name } },
    errors: [],
  }
%>
<%= content_tag :div, '', data: { react_component: 'HeirUpdatePage', props: page_props.to_json } %>
