# .env.example — ローカル開発用の環境変数テンプレート
#
# 使い方:
#   cp .env.example .env
#   （.env は .gitignore で除外済み。Git にはコミットされない）
#
# docker-compose.yml で値を直接書いているためこのファイルは主に参考用。
# docker compose を使わずに rails server を直接起動したい場合はこちらを使う。

# ── DB 接続 ──────────────────────────────────────────────
DB_HOST=127.0.0.1        # Docker 経由では db、ローカル直接起動では 127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password     # docker-compose.yml の MYSQL_ROOT_PASSWORD と合わせる
DB_NAME=sucseed_development
DB_NAME_TEST=sucseed_test

# ── Rails ────────────────────────────────────────────────
RAILS_ENV=development
SECRET_KEY_BASE=devsecret_local_only   # ローカル限定なので固定値で OK

# ── メール（今は使わない）───────────────────────────────
# メール送信機能を動かしたい場合は letter_opener gem か Gmail SMTP を設定する
# GMAIL_ADDRESS=your-email@gmail.com
# GMAIL_PASSWORD=your-app-password   # Gmail の「アプリパスワード」を使うこと
