# ────────────────────────────────────────────
# .env.example
#   このファイルをコピーして .env を作成してください
#     cp .env.example .env
#   .env は .gitignore に含まれており Git にはコミットされません
#   本番環境では各変数をサーバー環境に直接設定してください
# ────────────────────────────────────────────

# ──────────────────────────────────────────
# データベース接続設定
# ──────────────────────────────────────────

# Docker コンテナ内の MySQL サービス名 (docker-compose のサービス名と一致させる)
# ローカル直接起動時は 127.0.0.1 に変更
DB_HOST=db

DB_PORT=3306
DB_USERNAME=root

# MySQL root パスワード (ローカル開発用なので簡易なもので可)
DB_PASSWORD=password

# 開発用DB名
DB_NAME=sucseed_development

# テスト用DB名
DB_NAME_TEST=sucseed_test

# ──────────────────────────────────────────
# Rails 設定
# ──────────────────────────────────────────

RAILS_ENV=development

# SECRET_KEY_BASE: セッション暗号化に使うキー
# 本番では必ず `rails secret` で生成した値に置き換えること
SECRET_KEY_BASE=devsecret_please_change_in_production

# ──────────────────────────────────────────
# メール設定 (Gmail SMTP)
# 開発中は letter_opener 等のGem導入を検討、本番時に設定
# ──────────────────────────────────────────

# GMAIL_ADDRESS=your-email@gmail.com
# GMAIL_PASSWORD=your-app-password
