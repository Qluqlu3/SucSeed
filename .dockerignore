# ────────────────────────────────────────────
# .dockerignore
#   docker build 時にコンテキストから除外するファイル・ディレクトリ
#   これにより:
#     1. イメージサイズの削減
#     2. ビルドキャッシュの不要な無効化を防止
#     3. 機密ファイルのイメージへの混入防止
# ────────────────────────────────────────────

# Git 管理ファイル (.git は特に重要 — 含めるとイメージが大幅に肥大化する)
.git
.gitignore

# 機密ファイル (絶対にイメージに含めない)
.env
.env.*
!.env.example

# Node.js 依存パッケージ (コンテナ内でインストールするので不要)
node_modules/

# ログファイル
log/

# 一時ファイル / キャッシュ
tmp/

# テストカバレッジレポート
coverage/

# macOS ゴミファイル
.DS_Store

# エディタ設定
.vscode/
.idea/

# アップロードされたファイル (ボリュームでマウントするので不要)
public/uploads/

# README 等のドキュメント (アプリ動作に不要)
*.md
