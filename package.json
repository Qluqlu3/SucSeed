{
  "name": "SucSeed",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "biome check --write"
    ]
  },
  "scripts": {
    "build": "esbuild frontend/application.ts frontend/styles/fontawesome.css --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets --loader:.tsx=tsx --loader:.ts=ts --loader:.woff2=file --loader:.woff=file --loader:.ttf=file --loader:.eot=file --loader:.svg=file --asset-names=webfonts/[name]",
    "build:watch": "pnpm build --watch=forever",
    "build:css": "tailwindcss -i ./frontend/styles/tailwind.css -o ./app/assets/builds/tailwind.css --minify",
    "build:css:watch": "tailwindcss -i ./frontend/styles/tailwind.css -o ./app/assets/builds/tailwind.css --watch=always",
    "lint": "biome check frontend/",
    "lint:fix": "biome check --write frontend/",
    "format": "biome format --write frontend/",
    "prepare": "husky"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@tailwindcss/cli": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "three": "^0.184.0"
  }
}
